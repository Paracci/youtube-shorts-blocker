{
  "manifest_version": 3,
  "name": "YouTube Shorts Channel Blocker",
  "version": "1.7.0",
  "description": "Block unwanted YouTube Shorts channels, skip ads, and download videos in your preferred quality.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "YouTube Shorts Channel Blocker",
    "default_popup": "popup.html"
  },
  "permissions": [
    "downloads",
    "nativeMessaging",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.googlevideo.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_idle"
    }
  ]
}