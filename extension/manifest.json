{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.11.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_title": "YouTube Shorts Channel Blocker",
    "default_popup": "views/popup.html"
  },
  "permissions": [
    "downloads",
    "nativeMessaging",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.googlevideo.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "js/i18n/translations.js",
        "js/utils.js",
        "js/premium-detector.js",
        "js/state.js",
        "js/ad-blocker.js",
        "js/shorts-hider.js",
        "js/notifications.js",
        "js/channel-blocker.js",
        "js/downloader.js",
        "js/quality-lock.js",
        "js/content.js"
      ],
      "css": [
        "css/style.css"
      ],
      "run_at": "document_idle"
    }
  ]
}